# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Centfolio-specific
pocketbase/pb_data/
pocketbase/pocketbase
pocketbase/pocketbase.exe
scripts/seed-*.ts
scripts/seed-*.js
*.log
pocketbase/*.zip

# Sentry build plugin local config (auth token, etc.)
.env.sentry-build-plugin

# /impeccable critique snapshots are session-local trend records.
# ignore.md (the accepted-findings list) IS tracked; timestamps are not.
.impeccable/critique/2*.md

# Playwright test outputs (local + CI)
/test-results/
/playwright-report/
/playwright/.cache/
*.log

# Skills framework — .agents/ is the symlink target, restorable via `npx skills install`
.agents/
