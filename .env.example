# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PocketBase
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# Logging
LOG_LEVEL=debug

# Sentry (Phase 1+)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build time. Token from sentry.io/settings/auth-tokens/
# with scopes project:releases and org:read. Not needed at runtime.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Gemini (Phase 3+, receipt OCR and AI categorization)
GEMINI_API_KEY=

# GoCardless Bank Account Data (Phase 4+, bank sync)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Twelve Data (Phase 6+, stock prices)
TWELVEDATA_API_KEY=
